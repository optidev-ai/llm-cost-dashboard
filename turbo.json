{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "typecheck": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["node_modules/.tmp/**"],
      "cache": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}